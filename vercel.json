{
  "version": 2,
  "name": "edge-health-dashboard",
  "rewrites": [
    { 
      "source": "/(.*)", 
      "destination": "/api/index",
      "has": [
        {
          "type": "header",
          "key": "x-edge-debug",
          "value": "true"
        }
      ]
    },
    { "source": "/(.*)", "destination": "/api/index" }
  ],
  "cleanUrls": true,
  "trailingSlash": false
}
